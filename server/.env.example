# Server Configuration
PORT=3001
NODE_ENV=production

# Client URL (for CORS)
CLIENT_URL=https://vastuplan.app

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@ep-xyz-abc.region.aws.neon.tech/database?sslmode=require

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
SUPABASE_JWT_SECRET=your-supabase-project-jwt-secret

# Logging
LOG_LEVEL=info

# AI Provider: "gemini" or "ollama"
AI_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v4-pro

# Razorpay Payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Pro Export Pack pricing (paise; 49900 = ₹499)
PRO_EXPORT_PRICE_PAISE=49900
PRO_EXPORT_CURRENCY=INR
PRO_EXPORT_TIER=pro_export
PRO_EXPORT_DURATION_DAYS=365
