# Gemini AI: client code reads VITE_GEMINI_API_KEY (Vite standard).
# Set this in your local .env (and in the Vercel / hosting UI for deploys).
VITE_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Database Configuration (collaboration server only)
DATABASE_URL="postgres://user:password@localhost:5432/vastuplan"

# JWT Configuration (collaboration server only)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRY="15m"

# Server Configuration (collaboration server only)
PORT=3001
CLIENT_URL="http://localhost:3000"

# Collaboration Server
VITE_COLLAB_SERVER_URL="http://localhost:3001"

# Analytics (Plausible). Set VITE_ANALYTICS_ENABLED=false to disable.
# VITE_ANALYTICS_DOMAIN is the site domain registered in Plausible.
# VITE_ANALYTICS_API_HOST is the Plausible host (cloud or self-hosted).
VITE_ANALYTICS_ENABLED="true"
VITE_ANALYTICS_DOMAIN="vastuplan.app"
VITE_ANALYTICS_API_HOST="https://plausible.io"
