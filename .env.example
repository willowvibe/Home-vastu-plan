# AI API server URL (Railway)
VITE_API_URL="http://localhost:3001"

# Database Configuration (collaboration server only)
DATABASE_URL="postgres://user:password@localhost:5432/vastuplan"

# JWT Configuration (collaboration server only)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
SUPABASE_JWT_SECRET="your-supabase-project-jwt-secret"

# Server Configuration (collaboration server only)
PORT=3001
CLIENT_URL="http://localhost:3000"

# Razorpay Payments (server only)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"
PRO_EXPORT_PRICE_PAISE="49900"
PRO_EXPORT_CURRENCY="INR"
PRO_EXPORT_TIER="pro_export"
PRO_EXPORT_DURATION_DAYS="365"

# Collaboration Server
VITE_COLLAB_SERVER_URL="http://localhost:3001"

# Analytics (Plausible). Set VITE_ANALYTICS_ENABLED=false to disable.
# VITE_ANALYTICS_DOMAIN is the site domain registered in Plausible.
# VITE_ANALYTICS_API_HOST is the Plausible host (cloud or self-hosted).
VITE_ANALYTICS_ENABLED="true"
VITE_ANALYTICS_DOMAIN="vastuplan.app"
VITE_ANALYTICS_API_HOST="https://plausible.io"

# Supabase Auth (client). Use the URL and anon/public key from your project
# dashboard (Settings > API). The anon key is safe to expose in the browser.
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<your-anon-key>"
